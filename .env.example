# =============================================
# SEAPEDIA Backend — Environment Variables
# =============================================
# Copy this file as .env and fill in your values:
#   cp .env.example .env

# --- Database (PostgreSQL / Supabase) ---
# Format: jdbc:postgresql://<host>:<port>/<database>?sslmode=require
SUPABASE_DB_URL=jdbc:postgresql://db.<your-project-ref>.supabase.co:5432/postgres?sslmode=require
SUPABASE_DB_USERNAME=postgres
SUPABASE_DB_PASSWORD=your_database_password

# --- JWT ---
# Generate a secure secret: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_base64_encoded
JWT_EXPIRATION_MS=86400000
